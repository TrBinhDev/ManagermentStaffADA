generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum EmployeeStatus {
  ACTIVE
  RESIGNED
}

enum ManagerRole {
  OWNER
  MANAGER
}

// ============================================================
// PHÒNG BAN
// ============================================================

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions Position[]
}

// ============================================================
// VỊ TRÍ / CHỨC DANH
// ============================================================

model Position {
  id           String   @id @default(uuid())
  name         String
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department        Department        @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  employees         Employee[]
  positionHistories PositionHistory[]

  @@unique([name, departmentId])
}

// ============================================================
// NHÂN VIÊN (bảng lõi)
// ============================================================

model Employee {
  id         String         @id @default(uuid())
  code       String         @unique
  cccdHash   String         @unique
  fullName   String
  dob        DateTime?
  positionId String
  status     EmployeeStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  position          Position           @relation(fields: [positionId], references: [id], onDelete: Restrict)
  profile           EmployeeProfile?
  managerAccount    ManagerAccount?
  positionHistories PositionHistory[]
  employmentPeriods EmploymentPeriod[]
}

// ============================================================
// HỒ SƠ CHI TIẾT NHÂN VIÊN
// ============================================================

model EmployeeProfile {
  id            String @id @default(uuid())
  employeeId    String @unique
  cccdEncrypted String

  gender           String?
  ethnicity        String?
  religion         String?
  permanentAddress String?
  currentAddress   String?

  primaryPhone String?
  email        String?

  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  maritalStatus  String?
  educationLevel String?

  cccdIssueDate  DateTime?
  cccdIssuePlace String?

  bankName          String?
  bankAccountNumber String?
  bankAccountHolder String?

  avatarUrl String? @default("/default-avatar.png")
  note      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ============================================================
// TÀI KHOẢN ĐĂNG NHẬP
// ============================================================

model ManagerAccount {
  id           String      @id @default(uuid())
  employeeId   String?     @unique
  email        String      @unique
  passwordHash String
  role         ManagerRole
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

// ============================================================
// LỊCH SỬ VỊ TRÍ — theo dõi thời gian nhân viên giữ từng vị trí.
// endDate = null nghĩa là đang giữ vị trí đó. Số ngày luôn tính lúc đọc
// (endDate ?? now) - startDate, không lưu counter, không cần job nào chạy nền.
// ============================================================

model PositionHistory {
  id         String    @id @default(uuid())
  employeeId String
  positionId String
  startDate  DateTime  @default(now())
  endDate    DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Restrict)
}

// ============================================================
// LỊCH SỬ GẮN BÓ CÔNG TY — theo dõi từng đợt làm việc liên tục.
// endDate = null nghĩa là đang làm việc (đợt hiện tại). Resign đóng dòng
// đang mở, rehire mở dòng mới hoàn toàn (số ngày gắn bó tính lại từ đầu).
// ============================================================

model EmploymentPeriod {
  id         String    @id @default(uuid())
  employeeId String
  startDate  DateTime  @default(now())
  endDate    DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}