generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum EmployeeStatus {
  ACTIVE
  RESIGNED
}

enum ManagerRole {
  OWNER
  MANAGER
}

// ============================================================
// PHÒNG BAN
// ============================================================

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions Position[]
}

// ============================================================
// VỊ TRÍ / CHỨC DANH
// ============================================================

model Position {
  id           String   @id @default(uuid())
  name         String
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  employees  Employee[]

  @@unique([name, departmentId])
}

// ============================================================
// NHÂN VIÊN (bảng lõi)
// ============================================================

model Employee {
  id         String         @id @default(uuid())
  code       String         @unique
  cccdHash   String         @unique
  fullName   String
  dob        DateTime?
  positionId String
  status     EmployeeStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  position       Position         @relation(fields: [positionId], references: [id], onDelete: Restrict)
  profile        EmployeeProfile?
  managerAccount ManagerAccount?
}

// ============================================================
// HỒ SƠ CHI TIẾT NHÂN VIÊN
// ============================================================

model EmployeeProfile {
  id            String @id @default(uuid())
  employeeId    String @unique
  cccdEncrypted String

  gender           String?
  ethnicity        String?
  religion         String?
  permanentAddress String?
  currentAddress   String?

  primaryPhone String?
  email        String?

  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  maritalStatus  String?
  educationLevel String?

  cccdIssueDate  DateTime?
  cccdIssuePlace String?

  bankName          String?
  bankAccountNumber String?
  bankAccountHolder String?

  avatarUrl String? @default("/default-avatar.png")
  note      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ============================================================
// TÀI KHOẢN ĐĂNG NHẬP
// ============================================================

model ManagerAccount {
  id           String      @id @default(uuid())
  employeeId   String?     @unique
  email        String      @unique
  passwordHash String
  role         ManagerRole
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}