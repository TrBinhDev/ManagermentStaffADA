generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum EmployeeStatus {
  ACTIVE
  RESIGNED
}

enum ManagerRole {
  OWNER
  MANAGER
  STAFF
}

// ============================================================
// PHÒNG BAN
// ============================================================

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions Position[]
}

// ============================================================
// VỊ TRÍ / CHỨC DANH
// ============================================================

model Position {
  id           String   @id @default(uuid())
  name         String
  departmentId String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department        Department              @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  employees         Employee[]
  positionHistories PositionHistory[]
  salaryRates       PositionSalaryRate[]
  shiftCapacities   ShiftPositionCapacity[]
  dailyPayments     DailyPayment[]

  @@unique([name, departmentId])
}

// ============================================================
// NHÂN VIÊN (bảng lõi)
// ============================================================

model Employee {
  id         String         @id @default(uuid())
  code       String         @unique
  cccdHash   String         @unique
  fullName   String
  dob        DateTime?
  positionId String
  status     EmployeeStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  position          Position           @relation(fields: [positionId], references: [id], onDelete: Restrict)
  profile           EmployeeProfile?
  managerAccount    ManagerAccount?
  positionHistories PositionHistory[]
  employmentPeriods EmploymentPeriod[]
  workSchedules     WorkSchedule[]
  attendances       Attendance[]
  dailyPayments     DailyPayment[]
}

// ============================================================
// HỒ SƠ CHI TIẾT NHÂN VIÊN
// ============================================================

model EmployeeProfile {
  id            String @id @default(uuid())
  employeeId    String @unique
  cccdEncrypted String

  gender           String?
  ethnicity        String?
  religion         String?
  permanentAddress String?
  currentAddress   String?

  primaryPhone String?
  email        String?

  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  maritalStatus  String?
  educationLevel String?

  cccdIssueDate  DateTime?
  cccdIssuePlace String?

  bankName          String?
  bankAccountNumber String?
  bankAccountHolder String?

  avatarUrl String? @default("/default-avatar.png")
  note      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ============================================================
// TÀI KHOẢN ĐĂNG NHẬP
// ============================================================

model ManagerAccount {
  id           String      @id @default(uuid())
  employeeId   String?     @unique
  email        String      @unique
  passwordHash String
  role         ManagerRole
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  checkedInAttendances  Attendance[] @relation("AttendanceCheckedInBy")
  checkedOutAttendances Attendance[] @relation("AttendanceCheckedOutBy")
}

// ============================================================
// LỊCH SỬ VỊ TRÍ — theo dõi thời gian nhân viên giữ từng vị trí.
// endDate = null nghĩa là đang giữ vị trí đó. Số ngày luôn tính lúc đọc
// (endDate ?? now) - startDate, không lưu counter, không cần job nào chạy nền.
// ============================================================

model PositionHistory {
  id         String    @id @default(uuid())
  employeeId String
  positionId String
  startDate  DateTime  @default(now())
  endDate    DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Restrict)
}

// ============================================================
// LỊCH SỬ GẮN BÓ CÔNG TY — theo dõi từng đợt làm việc liên tục.
// endDate = null nghĩa là đang làm việc (đợt hiện tại). Resign đóng dòng
// đang mở, rehire mở dòng mới hoàn toàn (số ngày gắn bó tính lại từ đầu).
// ============================================================

model EmploymentPeriod {
  id         String    @id @default(uuid())
  employeeId String
  startDate  DateTime  @default(now())
  endDate    DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ============================================================
// MỨC LƯƠNG THEO GIỜ CỦA VỊ TRÍ — có lịch sử, không sửa đè.
// effectiveTo = null nghĩa là mức đang áp dụng. Sửa lương = tạo mức mới,
// tự đóng mức cũ (effectiveTo = hôm nay), không xóa mức cũ.
// ============================================================

model PositionSalaryRate {
  id            String    @id @default(uuid())
  positionId    String
  hourlyRate    Decimal   @db.Decimal(12, 2)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date

  position Position @relation(fields: [positionId], references: [id], onDelete: Restrict)

  @@index([positionId])
}

// ============================================================
// DANH MỤC CA LÀM VIỆC
// ============================================================

model Shift {
  id        String   @id @default(uuid())
  name      String   @unique
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  capacities    ShiftPositionCapacity[]
  workSchedules WorkSchedule[]
  attendances   Attendance[]
}

// ============================================================
// GIỚI HẠN NHÂN SỰ THEO TỪNG CẶP (CA, VỊ TRÍ) — cặp chưa khai báo thì
// không giới hạn.
// ============================================================

model ShiftPositionCapacity {
  id         String @id @default(uuid())
  shiftId    String
  positionId String
  maxStaff   Int

  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([shiftId, positionId])
}

// ============================================================
// LỊCH LÀM VIỆC THEO NGÀY. workDate quy ước theo NGÀY KẾT THÚC ca
// (kể cả ca qua đêm) — áp dụng nhất quán với Attendance/DailyPayment.
// ============================================================

model WorkSchedule {
  id         String   @id @default(uuid())
  employeeId String
  shiftId    String
  workDate   DateTime @db.Date
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Restrict)

  @@unique([employeeId, shiftId, workDate])
}

// ============================================================
// CHẤM CÔNG THẬT (giờ vào + giờ ra). employee/attendance bị Restrict —
// còn dữ liệu chấm công/lương thì không cho xóa cứng Employee.
// ============================================================

model Attendance {
  id             String    @id @default(uuid())
  employeeId     String
  shiftId        String
  workDate       DateTime  @db.Date
  checkedInAt    DateTime?
  checkedOutAt   DateTime?
  checkedInById  String
  checkedOutById String?

  employee     Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  shift        Shift           @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  checkedInBy  ManagerAccount  @relation("AttendanceCheckedInBy", fields: [checkedInById], references: [id], onDelete: Restrict)
  checkedOutBy ManagerAccount? @relation("AttendanceCheckedOutBy", fields: [checkedOutById], references: [id], onDelete: Restrict)
  dailyPayment DailyPayment?

  @@unique([employeeId, workDate, shiftId])
}

// ============================================================
// TIỀN CÔNG TỪNG NGÀY — tự sinh khi check-out, không có API tạo/sửa tay.
// hourlyRate + positionId snapshot tại thời điểm workDate, không đổi dù
// Position/PositionSalaryRate sau này thay đổi.
// ============================================================

model DailyPayment {
  id           String   @id @default(uuid())
  attendanceId String   @unique
  employeeId   String
  positionId   String
  workDate     DateTime @db.Date
  hoursWorked  Decimal  @db.Decimal(6, 2)
  hourlyRate   Decimal  @db.Decimal(12, 2)
  amount       Decimal  @db.Decimal(14, 2)

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  position   Position   @relation(fields: [positionId], references: [id], onDelete: Restrict)

  @@index([employeeId, workDate])
}